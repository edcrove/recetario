{
  "name": "@recetario/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "predev": "pnpm --filter @recetario/shared build",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "pretest": "pnpm --filter @recetario/shared build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration-coverage": "vitest run --config vitest.integration.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "generate-key": "tsx src/scripts/generate-key.ts",
    "seed": "tsx src/scripts/seed.ts",
    "seed:e2e-accounts": "tsx src/scripts/seed-e2e-accounts.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@recetario/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "postgres": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@vitest/coverage-v8": "^3.2.7",
    "drizzle-kit": "^0.31.0",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.7"
  }
}
