{
  "name": "@recetario/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "generate-key": "tsx src/scripts/generate-key.ts",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@recetario/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "postgres": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.3",
    "@vitest/coverage-v8": "^3.2.6",
    "drizzle-kit": "^0.31.0",
    "testcontainers": "^12.0.3",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
