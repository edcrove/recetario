{
  "name": "recetario-app",
  "version": "0.3.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "build": "expo export --platform web",
    "build:coverage": "BABEL_ENV=coverage expo export --platform web --output-dir dist-coverage",
    "lint": "eslint app",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:screens": "vitest run --config vitest.screen.config.ts",
    "test:e2e": "playwright test",
    "test:e2e-coverage": "E2E_COVERAGE=true playwright test",
    "coverage:e2e-merge": "nyc merge .e2e-coverage .nyc_output/out.json && node e2e/remap-coverage.js && nyc report",
    "coverage:e2e-report": "nyc report --reporter=lcov --reporter=html --reporter=text"
  },
  "dependencies": {
    "@expo/metro-runtime": "^56.0.16",
    "@recetario/shared": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "expo": "~56.0.15",
    "expo-keep-awake": "~56.0.3",
    "expo-router": "~56.2.14",
    "expo-secure-store": "~56.0.4",
    "expo-speech": "~56.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native": "^0.86.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@playwright/test": "^1.61.1",
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^14.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.7",
    "babel-jest": "^29.7.0",
    "babel-plugin-istanbul": "^8.0.0",
    "babel-preset-expo": "^57.0.3",
    "c8": "^11.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "jsdom": "^29.1.1",
    "nyc": "^18.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.7"
  }
}
