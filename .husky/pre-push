#!/bin/sh
# Replicates the CI pipeline locally before every push.
# Aborts the push if any step fails.
# Set SKIP_PRE_PUSH=1 to bypass (emergency only).

if [ "$SKIP_PRE_PUSH" = "1" ]; then
  echo "⚠️  pre-push hook skipped (SKIP_PRE_PUSH=1)"
  exit 0
fi

echo "🔍 pre-push: running CI checks..."
EVIDENCE_FILE=".last-ci-output.txt"

echo "=== Lint ===" > "$EVIDENCE_FILE"
if ! pnpm turbo run lint >> "$EVIDENCE_FILE" 2>&1; then
  echo "❌ Lint failed. Push aborted."; exit 1
fi

echo "" >> "$EVIDENCE_FILE"
echo "=== Typecheck ===" >> "$EVIDENCE_FILE"
if ! pnpm turbo run typecheck >> "$EVIDENCE_FILE" 2>&1; then
  echo "❌ Typecheck failed. Push aborted."; exit 1
fi

echo "" >> "$EVIDENCE_FILE"
echo "=== Tests ===" >> "$EVIDENCE_FILE"
if ! pnpm turbo run test >> "$EVIDENCE_FILE" 2>&1; then
  echo "❌ Tests failed. Push aborted."; exit 1
fi

echo "" >> "$EVIDENCE_FILE"
echo "=== Build ===" >> "$EVIDENCE_FILE"
if ! pnpm turbo run build >> "$EVIDENCE_FILE" 2>&1; then
  echo "❌ Build failed. Push aborted."; exit 1
fi

# Show summary from evidence file
grep -E "Tasks:|Tests |Duration" "$EVIDENCE_FILE" | tail -8

echo ""
echo "✅ All checks passed — pushing."
echo "(Evidence saved to $EVIDENCE_FILE for use in PR description)"
