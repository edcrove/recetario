#!/bin/sh
# Replicates the CI pipeline locally before every push.
# Aborts the push if any step fails.
# Set SKIP_PRE_PUSH=1 to bypass (emergency only).

if [ "$SKIP_PRE_PUSH" = "1" ]; then
  echo "⚠️  pre-push hook skipped (SKIP_PRE_PUSH=1)"
  exit 0
fi

echo "🔍 pre-push: running CI checks..."
EVIDENCE_FILE=".last-ci-output.txt"
> "$EVIDENCE_FILE"

fail() {
  echo "\n❌ pre-push: $1 failed. Push aborted."
  exit 1
}

run_step() {
  STEP_NAME="$1"
  shift
  echo "\n=== $STEP_NAME ===" | tee -a "$EVIDENCE_FILE"
  OUTPUT=$("$@" 2>&1)
  CODE=$?
  echo "$OUTPUT" | tail -4 | tee -a "$EVIDENCE_FILE"
  [ $CODE -ne 0 ] && fail "$STEP_NAME"
}

run_step "Lint"       pnpm turbo run lint
run_step "Typecheck"  pnpm turbo run typecheck
run_step "Tests"      pnpm turbo run test
run_step "Build"      pnpm turbo run build

echo "\n✅ All checks passed — pushing."
echo "(Evidence saved to $EVIDENCE_FILE for use in PR description)"
