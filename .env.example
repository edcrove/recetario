# ── Recetario — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit real secrets.
#
# For docker compose (full stack): only JWT_SECRET and EXPO_PUBLIC_API_URL are needed.
# For local dev (pnpm dev): all vars below apply per-package.

# ── API (packages/api) ──────────────────────────────────────────────────────

# Postgres connection string (required)
DATABASE_URL=postgres://recetario:recetario@localhost:5432/recetario

# JWT signing secret (required in production — must be at least 64 random hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production

# API key for local development and CI (optional — skips DB lookup for auth)
# Generate a real key with: pnpm --filter @recetario/api exec tsx src/scripts/generate-key.ts
DEV_API_KEY=

# ── MCP server (packages/mcp) ────────────────────────────────────────────────

# Base URL of the API the MCP server calls
API_BASE_URL=http://localhost:3000

# API key the MCP server uses to authenticate with the API
# Must match a key in the api_keys table (run generate-key.ts and insert the hash)
MCP_API_KEY=

# ── Expo app (apps/app) ──────────────────────────────────────────────────────
# EXPO_PUBLIC_* vars are embedded at build time and visible in the client bundle.
# Do NOT put secrets here.

# API base URL for the Expo app
EXPO_PUBLIC_API_URL=http://localhost:3000

# API key for the Expo app (optional — for direct API access without MCP)
EXPO_PUBLIC_API_KEY=
